APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Parent domain for production (used in CORS patterns: https://{slug}.{APP_PLATFORM_DOMAIN}).
APP_PLATFORM_DOMAIN=apex.com
# Optional override for welcome-email login URLs; defaults to APP_PLATFORM_DOMAIN (see config('app.platform_domain')).
# PLATFORM_DOMAIN=apex.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Central (landlord) database — clinics registry, platform admins, subscriptions
DB_DATABASE=apex_central
DB_USERNAME=root
DB_PASSWORD=

# Tenant DBs are created per clinic: apex_clinic_{slug} (hyphens in slug → underscores)

# API is served at api.{APP_PLATFORM_DOMAIN} for all tenants; clinic SPA stays at {slug}.{APP_PLATFORM_DOMAIN}.
# Tenant API requests must send X-Tenant-Slug (see ResolveTenantFromHeader).
# TENANCY_CENTRAL_DOMAINS: landlord / non-tenant hosts only (comma-separated), not each clinic host.
TENANCY_CENTRAL_DOMAINS=localhost,127.0.0.1

# Local/dev without MySQL: use sqlite instead
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leading dot: cookie visible on api.* and all {slug}.* subdomains (required for cross-subdomain session cookies).
# Local example: .localhost — production: .apex.com (match APP_PLATFORM_DOMAIN).
SESSION_DOMAIN=.localhost
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true

# Sanctum SPA cookie auth: include the API host and every clinic SPA origin pattern (Referer/Origin match).
# Example production: api.apex.com,*.apex.com,*.apex.com:5173
# Local: api.localhost,*.localhost,*.localhost:5173 (use one platform name consistently).
SANCTUM_STATEFUL_DOMAINS=api.localhost,*.localhost,*.localhost:5173,localhost:8000

# Optional extra CORS origins (comma-separated). Primary allowlist is allowed_origins_patterns in config/cors.php (clinic subdomains + APP_PLATFORM_DOMAIN).
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
# CORS_SUPPORTS_CREDENTIALS=true

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# Comma-separated WebSocket allowed origins (default * for local dev). Production: https://yourapp.com,https://*.yourapp.com
REVERB_ALLOWED_ORIGINS=*

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

VITE_API_URL=http://api.localhost
