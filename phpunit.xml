<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="DB_CONNECTION" value="central" force="true"/>
        <env name="CENTRAL_DB_DRIVER" value="sqlite" force="true"/>
        <env name="CENTRAL_DB_DATABASE" value="testing.sqlite" force="true"/>
        <env name="TENANT_DB_TEMPLATE_CONNECTION" value="sqlite" force="true"/>
        <env name="APP_URL" value="http://apex.test" force="true"/>
        <env name="TENANCY_CENTRAL_DOMAINS" value="apex.test" force="true"/>
        <env name="TENANCY_ROUTES" value="true" force="true"/>
        <env name="SANCTUM_STATEFUL_DOMAINS" value="apex.test,.apex.test,*.apex.test" force="true"/>
        <env name="SESSION_DOMAIN" value=".apex.test" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="database" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
